# ─── Discord ────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your-bot-token
DISCORD_APP_ID=your-application-id
# Default registration discovers every guild the bot is in and deploys guild-scoped commands.
DISCORD_DEPLOY_ALL_GUILDS=true
DISCORD_DEPLOY_GLOBAL_COMMANDS=false
# Optional when DISCORD_DEPLOY_ALL_GUILDS=false: restrict slash-command registration to one guild.
DISCORD_DEV_GUILD_ID=
# Optional privileged gateway intent. Enable in Discord developer portal before setting true.
DISCORD_GUILD_MEMBERS_INTENT=false

# ─── Persona (who the bot is) ───────────────────────────────────────────────
# Fully generic by default. Set these to make it whoever you want. {NAME} in the
# persona/dream-voice templates is replaced with BOT_NAME.
BOT_NAME=Hikari-chan
# BOT_PERSONA_PATH=personas/hikari-merged.xml
# BOT_PERSONA=You are {NAME}, ...
# BOT_DREAM_VOICE=Write in {NAME}'s own first-person voice ...

# ─── Conversation handling (Letta-inspired) ─────────────────────────────────
# Coalesce rapid-fire messages into one turn before replying (ms). 0 = reply each.
BATCH_MS=1500
# How many recent channel messages to feed as conversational context.
HISTORY_N=6
# Replying to bot-authored messages is opt-in; bot messages can still appear in context.
DISCORD_RESPOND_TO_BOTS=false
# Read-only Discord inspection tools for the chat LLM.
DISCORD_TOOLS_ENABLED=true
# Read text-like Discord attachments on addressed messages.
DISCORD_TEXT_ATTACHMENT_MAX_BYTES=409600
DISCORD_TEXT_ATTACHMENT_MAX_FILES=4
DISCORD_TEXT_ATTACHMENT_MAX_CHARS=409600
DISCORD_PDF_ATTACHMENT_MAX_PAGES=16

# Owner-only Codex bridge queue. Writes request JSON files only; does not execute Codex from Discord.
DISCORD_CODEX_BRIDGE_ENABLED=false
DISCORD_CODEX_BRIDGE_QUEUE=codex_bridge
DISCORD_CODEX_THREAD_ID=019e53da-7adc-7251-a203-e9da141553f7
DISCORD_CODEX_BRIDGE_PROMPT_MAX_CHARS=6000
DISCORD_CODEX_CONTEXT_SUMMARY_CHARS=700

# ─── Web search tools ───────────────────────────────────────────────────────
# Optional read-only Tavily search/extract/crawl/map/research tools for explicit lookup/current-info requests.
# Also accepts TAVILY_API_TOKEN or TVLY_API_KEY.
TAVILY_API_KEY=
TAVILY_TOOLS_ENABLED=false
TAVILY_TOOL_TIMEOUT=30
TAVILY_TOOL_MAX_RESULTS=5
TAVILY_TOOL_MAX_URLS=5
TAVILY_TOOL_CRAWL_LIMIT=25
TAVILY_TOOL_MAP_LIMIT=75
TAVILY_TOOL_RESEARCH_TIMEOUT=60

# ─── LLM providers ──────────────────────────────────────────────────────────
# Vercel AI Gateway is the default text-model lane. https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key
LLM_PROVIDER=vercel

# Model routing. The main reply and background cognition/dream roles are separate.
MODEL_CHAT=deepseek/deepseek-v4-pro
MODEL_REASONER=deepseek/deepseek-v4-flash
MODEL_FAST=deepseek/deepseek-v4-flash

# Gateway routing preferences (cost | latency | throughput)
GATEWAY_SORT=throughput

# Optional direct GLM lanes. /provider can switch live when these are configured.
ZAI_API_KEY=
ZAI_CODING_API_KEY=
GLM_MAIN_MODEL=glm-4.5-flash
GLM_DREAM_MODEL=glm-4.5-flash
GLM_JSON_MODEL=glm-4.5-flash
GLM_CODING_MAIN_MODEL=glm-5.2
GLM_CODING_DREAM_MODEL=zai:glm-4.5-flash
GLM_CODING_JSON_MODEL=zai:glm-4.5-flash

# ─── Embeddings ─────────────────────────────────────────────────────────────
# Local embeddings are authoritative by default: no embedding API spend.
EMBED_PROVIDER=local
EMBED_LOCAL_MODEL=Xenova/all-MiniLM-L6-v2
EMBED_LOCAL_BACKUP=true
EMBED_DIM=384
# Used only when EMBED_PROVIDER=vercel.
MODEL_EMBED=openai/text-embedding-3-small

# Native Discord voice messages via Fish Audio.
FISH_API_KEY=
FISH_VOICE_ID=
# Empty = account default. Set only when you explicitly want a Fish model/backbone.
FISH_MODEL=
FISH_BASE_URL=https://api.fish.audio
FISH_FORMAT=mp3
TTS_DELIVERY=voice_message
TTS_ENABLED=false
TTS_MAX_CHARS=800
TTS_TIMEOUT_MS=20000
TTS_OUTPUT_ROOT=./data/tts
TTS_FFMPEG_BIN=ffmpeg
TTS_VOICE_TARGET_PEAK=0.82
TTS_VOICE_OPUS_BITRATE=32k
TTS_VOICE_UPLOAD_TIMEOUT_MS=30000
TTS_FISH_TAGS_ENABLED=true

# ─── Memory store ───────────────────────────────────────────────────────────
# Leave empty for the persistent local file store at data/memories.json.
# Set Postgres + pgvector only when you explicitly need it.
DATABASE_URL=

# ─── Dreaming worker ────────────────────────────────────────────────────────
# Redis enables a durable BullMQ queue. Leave empty to use the in-process
# interval scheduler instead.
REDIS_URL=
# How often the bot "sleeps" and dreams, in minutes.
DREAM_INTERVAL_MIN=30
# Idle gate: only dream if the channel has been quiet this many minutes.
DREAM_IDLE_MIN=10

# ─── Developmental cognition lab ────────────────────────────────────────────
# Structured pre-reply appraisal, evidence-linked predictions, observed outcome
# learning, prospective dream rehearsal, slow self-development, and policy lab.
DEVELOPMENT_ENABLED=true
DEVELOPMENT_COGNITIVE_PREPASS=true
# deterministic is the measured fast default; adaptive enables a timeout-bounded Flash experiment.
DEVELOPMENT_COGNITIVE_MODE=deterministic
DEVELOPMENT_COGNITIVE_SAMPLE_RATE=0.05
DEVELOPMENT_COGNITIVE_TIMEOUT_MS=2500
DEVELOPMENT_EVENT_PATH=./data/development/events.jsonl
DEVELOPMENT_OUTCOME_WINDOW_HOURS=24
DEVELOPMENT_IMPLICIT_OUTCOME_WINDOW_MINUTES=30
DEVELOPMENT_MAX_PREDICTIONS=3
DEVELOPMENT_UTILITY_ALPHA=0.2
DEVELOPMENT_UTILITY_WEIGHT=0.2
DEVELOPMENT_UTILITY_MIN_RELEVANCE=0.2
DEVELOPMENT_SIMULATIONS_PER_DREAM=3
DEVELOPMENT_SELF_DELTA_MIN_EVIDENCE=3
DEVELOPMENT_SELF_DELTA_MIN_CYCLES=2
DEVELOPMENT_POLICY_LAB=true
# local-baseline mirrors live retrieval; local-diversity is a no-cost shadow reranker.
# Shadow output is logged and never enters the live prompt.
DEVELOPMENT_SHADOW_PROVIDER=local-diversity

# ─── Retrieval tuning (Generative Agents weights) ───────────────────────────
RETRIEVAL_W_RELEVANCE=1.0
RETRIEVAL_W_IMPORTANCE=1.0
RETRIEVAL_W_RECENCY=1.0
RECENCY_HALFLIFE_HOURS=24

LOG_LEVEL=info
